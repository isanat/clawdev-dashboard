// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// CLAWDEV Models

model Learning {
  id          String   @id @default(cuid())
  insight     String
  category    String   // "error", "optimization", "pattern", "security"
  context     String?
  actionTaken String?
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" or "assistant"
  content   String
  provider  String?  // "zai", "groq", "local"
  timestamp DateTime @default(now())
}

model Log {
  id        String   @id @default(cuid())
  level     String   // "INFO", "WARN", "ERROR", "DEBUG"
  message   String
  source    String?  // "agent", "api", "system", "skill"
  metadata  String?  // JSON string for additional data
  timestamp DateTime @default(now())
}

model Action {
  id          String   @id @default(cuid())
  type        String   // "fix", "optimize", "deploy", "restart", "alert"
  description String
  status      String   // "pending", "approved", "rejected", "completed", "failed"
  result      String?
  autoApproved Boolean @default(false)
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  enabled     Boolean  @default(true)
  usageCount  Int      @default(0)
  lastUsed    DateTime?
  category    String   // "scanner", "analyzer", "security", "automation"
}

model AgentConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  description     String?
  updatedAt       DateTime @updatedAt
}

model Metric {
  id          String   @id @default(cuid())
  name        String
  value       Float
  unit        String?
  category    String   // "system", "api", "agent"
  timestamp   DateTime @default(now())
}
